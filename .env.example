# ============================================================
# SUPABASE CONFIGURATION
# Source: Supabase Dashboard → Your Project → Project Settings → API
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================================
# PRISMA DATABASE CONNECTION
# Source: Supabase Dashboard → Your Project → Project Settings → Database
# DATABASE_URL  → Use "Connection Pooling" string → Port 6543 (for runtime queries)
# DIRECT_URL    → Use "Direct Connection" string  → Port 5432 (for Prisma migrations)
# ============================================================
DATABASE_URL="postgresql://postgres.your-project-id:your-password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.your-project-id:your-password@aws-0-region.pooler.supabase.com:5432/postgres"
# ============================================================
# NEXT.JS APPLICATION
# ============================================================
NEXTAUTH_SECRET=YOUR_RANDOM_SECRET_KEY_HERE
NEXTAUTH_URL=http://localhost:3000

# ============================================================
# NODE ENVIRONMENT
# ============================================================
NODE_ENV=development
