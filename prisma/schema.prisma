generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String                 @id @default(cuid())
  email               String                 @unique
  passwordHash        String
  firstName           String
  lastName            String
  idNumber            String                 @unique
  department          String
  role                UserRole
  specialization      Specialization?
  accountStatus       AccountStatus          @default(PENDING)
  avatarUrl           String?
  contactNumber       String?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  auditLogs           AuditLog[]
  assignedByRequests  MaintenanceRequest[]   @relation("AssignedByRequests")
  assignedRequests    MaintenanceRequest[]   @relation("AssignedToRequests")
  reviewedRequests    MaintenanceRequest[]   @relation("ReviewedRequests")
  submittedRequests   MaintenanceRequest[]   @relation("SubmittedRequests")
  notifications       Notification[]
  repairNotes         RepairNote[]
  assignmentsMade     RequestAssignment[]    @relation("AssignedBy")
  assignmentsReceived RequestAssignment[]    @relation("AssignedTo")
  statusChanges       RequestStatusHistory[]
  updatedSettings     SystemSettings[]
}

model MaintenanceRequest {
  id                 String                 @id @default(cuid())
  requestCode        String                 @unique
  submittedById      String
  issueType          IssueType
  building           Building
  roomNumber         String
  locationNotes      String?
  description        String
  urgencyLevel       UrgencyLevel
  status             RequestStatus          @default(PENDING)
  priorityLevel      PriorityLevel          @default(NORMAL)
  photoUrl           String?
  adminNotes         String?
  rejectionReason    String?
  cancellationReason String?
  reviewedById       String?
  reviewedAt         DateTime?
  assignedToId       String?
  assignedById       String?
  assignedAt         DateTime?
  startedAt          DateTime?
  completedAt        DateTime?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  assigner           User?                  @relation("AssignedByRequests", fields: [assignedById], references: [id])
  assignee           User?                  @relation("AssignedToRequests", fields: [assignedToId], references: [id])
  reviewer           User?                  @relation("ReviewedRequests", fields: [reviewedById], references: [id])
  submitter          User                   @relation("SubmittedRequests", fields: [submittedById], references: [id])
  notifications      Notification[]
  repairNote         RepairNote?
  assignments        RequestAssignment[]
  statusHistory      RequestStatusHistory[]

  @@index([status])
  @@index([submittedById])
  @@index([assignedToId])
  @@index([urgencyLevel])
  @@index([createdAt])
}

model RequestAssignment {
  id           String             @id @default(cuid())
  requestId    String
  assignedToId String
  assignedById String
  notes        String?
  isActive     Boolean            @default(true)
  assignedAt   DateTime           @default(now())
  revokedAt    DateTime?
  assigner     User               @relation("AssignedBy", fields: [assignedById], references: [id])
  assignee     User               @relation("AssignedTo", fields: [assignedToId], references: [id])
  request      MaintenanceRequest @relation(fields: [requestId], references: [id])
}

model RequestStatusHistory {
  id             String             @id @default(cuid())
  requestId      String
  changedById    String
  previousStatus RequestStatus?
  newStatus      RequestStatus
  remarks        String?
  changedAt      DateTime           @default(now())
  actor          User               @relation(fields: [changedById], references: [id])
  request        MaintenanceRequest @relation(fields: [requestId], references: [id])

  @@index([requestId])
  @@index([changedAt])
}

model RepairNote {
  id            String             @id @default(cuid())
  requestId     String             @unique
  technicianId  String
  notes         String
  partsReplaced String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  request       MaintenanceRequest @relation(fields: [requestId], references: [id])
  technician    User               @relation(fields: [technicianId], references: [id])
}

model Notification {
  id        String              @id @default(cuid())
  userId    String
  type      NotifType
  title     String
  message   String
  isRead    Boolean             @default(false)
  requestId String?
  createdAt DateTime            @default(now())
  request   MaintenanceRequest? @relation(fields: [requestId], references: [id])
  user      User                @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model AuditLog {
  id                 String      @id @default(cuid())
  userId             String?
  action             AuditAction
  affectedRecordId   String?
  affectedRecordType String?
  ipAddress          String?
  userAgent          String?
  details            String?
  createdAt          DateTime    @default(now())
  user               User?       @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model SystemSettings {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedById String?
  updatedAt   DateTime @updatedAt
  updater     User?    @relation(fields: [updatedById], references: [id])
}

enum UserRole {
  STUDENT
  FACULTY
  STAFF
  TECHNICIAN
  ADMIN
  USER
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  PENDING
}

enum RequestStatus {
  PENDING
  ONGOING
  COMPLETED
  REJECTED
  CANCELLED
}

enum UrgencyLevel {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum PriorityLevel {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum IssueType {
  HVAC
  ELECTRICAL
  PLUMBING
  CARPENTRY
  STRUCTURAL
  OTHERS
}

enum Building {
  IT_BUILDING
  ADMIN_BUILDING
  LIBRARY
  GYMNASIUM
  CANTEEN
  DORMITORY
  OTHERS
}

enum Specialization {
  HVAC
  ELECTRICAL
  PLUMBING
  CARPENTRY
  GENERAL
}

enum NotifType {
  REQUEST_SUBMITTED
  REQUEST_APPROVED
  REQUEST_REJECTED
  REQUEST_CANCELLED
  TASK_ASSIGNED
  STATUS_UPDATED
  TASK_COMPLETED
  REMINDER
}

enum AuditAction {
  LOGIN
  LOGOUT
  REQUEST_SUBMITTED
  REQUEST_APPROVED
  REQUEST_REJECTED
  REQUEST_CANCELLED
  TASK_ASSIGNED
  TASK_REASSIGNED
  STATUS_UPDATED
  TASK_COMPLETED
  USER_CREATED
  USER_UPDATED
  USER_DEACTIVATED
  PASSWORD_RESET
}
